# Refresh interval in seconds
refresh_seconds: 30

# Timezone for timestamp display
timezone: UTC

# Display backend configuration
display:
  # Backend: "mock" (PNG file), "waveshare_2in13_v3" (Waveshare 2.13" V3 e-paper)
  backend: mock
  # EPD native resolution (Waveshare 2.13" V3 = 122x250 portrait)
  width: 122
  height: 250
  rotation: 0
  # Full refresh every N cycles to clear ghosting (e-paper only, higher = fewer flashes)
  full_refresh_every_n_updates: 50

# Screen cycling configuration
screens:
  - name: health
    type: health
    poll_interval: 30
    display_duration: 30

  - name: tamagotchi
    type: tamagotchi
    poll_interval: 5
    display_duration: 15
    options:
      url: https://lotus.therektgames.com/health
      stats_url: https://lotus.therektgames.com/stats

# Status providers (used by the health screen)
# display_names maps upstream component names to short display labels
providers:
  - name: Claude
    type: statuspage
    url: https://status.claude.com/api/v2/summary.json
    components:
      - claude.ai
      - Claude Code
      - Claude API (api.anthropic.com)
    display_names:
      claude.ai: AI
      Claude Code: Code
      Claude API (api.anthropic.com): API

  - name: OpenAI
    type: statuspage
    url: https://status.openai.com/api/v2/summary.json
    components:
      - App
      - Conversations
      - Codex Web
      - Codex API
    display_names:
      App: App
      Conversations: Chat
      Codex Web: Web
      Codex API: API

  - name: Lotus
    type: lotus_health
    url: https://lotus.therektgames.com/health
    components: []
    display_names:
      Lotus: Live
      Queue: Queue
      Proxy: Proxy
