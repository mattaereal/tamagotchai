# Screen definitions for the e-paper display.
# The scheduler cycles through each screen in order.
#
# Default shipped screen: OpenCode agent feed.
# If the plugin is not running, the screen shows setup instructions
# instead of a cryptic offline error.
#
# To change the agent URL, replace 127.0.0.1 with your agent machine's IP:
#   ip addr show            # (on the agent machine)
#   hostname -I             # (on the agent machine)

screens:
  - name: OpenCode
    template: agent_feed
    poll_interval: 5
    display_duration: 15
    stale_threshold: 120
    agents:
      - name: OpenCode
        url: http://127.0.0.1:7788/status

  # --- Optional: add more screens below ---
  #
  # --- status_board: category/bullet status display ---
  # Category types:
  #   statuspage - Atlassian Statuspage adapter
  #   json - Fetch raw JSON, map item keys to statuses by convention
  #          (ok/up/true/0=OK, degraded/warning/non-zero=DEGRADED,
  #           down/error/false=DOWN, else UNKNOWN)
  # Item keys use dot-notation for nested access (e.g. "status.health")
  #
  # Built-in icons: anthropic, openai, lotus, generic
  # Custom icons: path to a 12x12 PNG file
  # - name: AI Health
  #   template: status_board
  #   poll_interval: 30
  #   display_duration: 30
  #   categories:
  #     - name: Claude
  #       url: https://status.claude.com/api/v2/summary.json
