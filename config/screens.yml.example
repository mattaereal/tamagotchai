# Screen definitions for the e-paper display.
# The scheduler cycles through each screen in order.
#
# Default screens:
#   1. OpenCode detail (local agent)
#   2. AI Services status board (OpenAI, Anthropic, GitHub, local agent)
#   3. Device vitals (CPU, memory, disk, WiFi, battery)
#
# Users can comment/uncomment info_lines to customize the OpenCode screen.
# All keys use dot-notation (e.g. metadata.model).

screens:
  # --- Local agent detail ---
  - name: OpenCode
    type: opencode
    poll_interval: 5
    display_duration: 15
    stale_threshold: 120
    url: http://127.0.0.1:7788/status
    info_lines:
      # Core fields -- comment/uncomment to customize
      - label: model
        key: metadata.model
        max_length: 18
      - label: tok
        template: "{0} / {1}"
        keys: [metadata.tokens_input, metadata.tokens_output]
        max_length: 20
      - label: cost
        template: "{0}"
        keys: [metadata.cost_usd]
        max_length: 12
      - label: tool
        key: metadata.tool_name
        max_length: 16
      - label: files
        key: metadata.files_modified
        max_length: 12
      - label: msgs
        key: metadata.message_count
        max_length: 12
      - label: duration
        key: metadata.session_duration_ms
        max_length: 14
      - label: diff
        template: "+{0} / -{1}"
        keys: [metadata.lines_added, metadata.lines_removed]
        max_length: 16
      - label: commits
        key: metadata.commits
        max_length: 10

  # --- AI service health ---
  - name: AI Services
    type: status_board
    poll_interval: 60
    display_duration: 15
    categories:
      - name: OpenAI
        url: https://status.openai.com/api/v2/summary.json
        type: statuspage
        icon: openai
        items:
          - key: Overall
            label: API
      - name: Anthropic
        url: https://status.claude.com/api/v2/summary.json
        type: statuspage
        icon: anthropic
        items:
          - key: Overall
            label: AI
      - name: GitHub
        url: https://www.githubstatus.com/api/v2/summary.json
        type: statuspage
        icon: github
        items:
          - key: Overall
            label: GH
      # OpenRouter has no public JSON status endpoint yet
      # - name: OpenRouter
      #   url: YOUR_OPENROUTER_STATUS_URL
      #   type: json
      #   icon: generic
      #   items:
      #     - key: status
      #       label: API
      - name: OpenCode
        url: http://127.0.0.1:7788/status
        type: json
        icon: generic
        items:
          - key: status
            label: Agent

  # --- Local device vitals ---
  - name: Device
    type: device_status
    poll_interval: 30
    display_duration: 15
